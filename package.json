{
  "name": "id-ae-bridge",
  "version": "1.0.0",
  "description": "Adobe Bridge - InDesign, Illustrator, Photoshop to After Effects",
  "main": "src/main.js",
  "author": "Adobe Bridge",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --win --x64 --dir",
    "build": "electron-builder --win --x64"
  },
  "dependencies": {
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.idbridge.app",
    "productName": "Adobe Bridge",
    "copyright": "Adobe Bridge",
    "directories": { "output": "dist" },
    "files": [
      "src/**/*",
      "assets/**/*"
    ],
    "extraResources": [
      { "from": "cep", "to": "cep" }
    ],
    "win": {
      "target": [
        { "target": "dir", "arch": ["x64"] }
      ]
    }
  }
}
