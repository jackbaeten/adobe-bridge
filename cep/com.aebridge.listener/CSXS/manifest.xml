<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<ExtensionManifest ExtensionBundleId="com.aebridge.listener"
                   ExtensionBundleName="AE Bridge"
                   ExtensionBundleVersion="1.0.0"
                   Version="6.0">
  <ExtensionList>
    <Extension Id="com.aebridge.listener.panel" Version="1.0.0"/>
    <Extension Id="com.aebridge.listener.bg" Version="1.0.0"/>
  </ExtensionList>
  <ExecutionEnvironment>
    <HostList>
      <Host Name="AEFT" Version="[22.0,99.9]"/>
    </HostList>
    <LocaleList><Locale Code="All"/></LocaleList>
    <RequiredRuntimeList>
      <RequiredRuntime Name="CSXS" Version="9.0"/>
    </RequiredRuntimeList>
  </ExecutionEnvironment>
  <DispatchInfoList>
    <Extension Id="com.aebridge.listener.panel">
      <DispatchInfo>
        <Resources>
          <MainPath>./panel/index.html</MainPath>
          <ScriptPath>./jsx/host.jsx</ScriptPath>
          <CEFCommandLine>
            <Parameter>--enable-nodejs</Parameter>
            <Parameter>--mixed-context</Parameter>
          </CEFCommandLine>
        </Resources>
        <Lifecycle><AutoVisible>true</AutoVisible></Lifecycle>
        <UI>
          <Type>Panel</Type>
          <Menu>AE Bridge</Menu>
          <Geometry>
            <Size><Width>220</Width><Height>300</Height></Size>
            <MinSize><Width>160</Width><Height>220</Height></MinSize>
          </Geometry>
        </UI>
      </DispatchInfo>
    </Extension>
    <Extension Id="com.aebridge.listener.bg">
      <DispatchInfo>
        <Resources>
          <MainPath>./bg/index.html</MainPath>
          <ScriptPath>./jsx/host.jsx</ScriptPath>
          <CEFCommandLine>
            <Parameter>--enable-nodejs</Parameter>
            <Parameter>--mixed-context</Parameter>
          </CEFCommandLine>
        </Resources>
        <Lifecycle>
          <AutoVisible>false</AutoVisible>
          <StartOn>
            <Event>com.adobe.csxs.events.ApplicationInitialized</Event>
            <Event>applicationActivate</Event>
          </StartOn>
        </Lifecycle>
        <UI>
          <Type>Custom</Type>
          <Geometry><Size><Width>1</Width><Height>1</Height></Size></Geometry>
        </UI>
      </DispatchInfo>
    </Extension>
  </DispatchInfoList>
</ExtensionManifest>
