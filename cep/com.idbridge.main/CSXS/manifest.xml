<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<ExtensionManifest ExtensionBundleId="com.idbridge.main"
                   ExtensionBundleName="ID>AE Bridge"
                   ExtensionBundleVersion="1.0.0"
                   Version="6.0">
  <ExtensionList>
    <Extension Id="com.idbridge.main.panel" Version="1.0.0"/>
    <Extension Id="com.idbridge.main.listener" Version="1.0.0"/>
  </ExtensionList>
  <ExecutionEnvironment>
    <HostList>
      <Host Name="IDSN" Version="[17.0,99.9]"/>
    </HostList>
    <LocaleList><Locale Code="All"/></LocaleList>
    <RequiredRuntimeList>
      <RequiredRuntime Name="CSXS" Version="9.0"/>
    </RequiredRuntimeList>
  </ExecutionEnvironment>
  <DispatchInfoList>
    <Extension Id="com.idbridge.main.panel">
      <DispatchInfo>
        <Resources>
          <MainPath>./main/index.html</MainPath>
          <ScriptPath>./jsx/host.jsx</ScriptPath>
          <CEFCommandLine>
            <Parameter>--enable-nodejs</Parameter>
            <Parameter>--mixed-context</Parameter>
          </CEFCommandLine>
        </Resources>
        <Lifecycle><AutoVisible>true</AutoVisible></Lifecycle>
        <UI>
          <Type>Panel</Type>
          <Menu>ID&gt;AE Bridge</Menu>
          <Geometry>
            <Size><Width>240</Width><Height>340</Height></Size>
            <MinSize><Width>180</Width><Height>260</Height></MinSize>
          </Geometry>
        </UI>
      </DispatchInfo>
    </Extension>
    <Extension Id="com.idbridge.main.listener">
      <DispatchInfo>
        <Resources>
          <MainPath>./listener/index.html</MainPath>
          <ScriptPath>./jsx/host.jsx</ScriptPath>
          <CEFCommandLine>
            <Parameter>--enable-nodejs</Parameter>
            <Parameter>--mixed-context</Parameter>
          </CEFCommandLine>
        </Resources>
        <Lifecycle>
          <AutoVisible>false</AutoVisible>
          <StartOn>
            <Event>com.adobe.csxs.events.ApplicationInitialized</Event>
            <Event>applicationActivate</Event>
          </StartOn>
        </Lifecycle>
        <UI>
          <Type>Custom</Type>
          <Geometry><Size><Width>1</Width><Height>1</Height></Size></Geometry>
        </UI>
      </DispatchInfo>
    </Extension>
  </DispatchInfoList>
</ExtensionManifest>
